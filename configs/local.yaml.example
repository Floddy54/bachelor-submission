# ──────────────────────────────────────────────────────────────────────────────
# local.yaml.example — per-developer local settings
# ──────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE
#   1. Copy this file to `configs/local.yaml` (same directory).
#        Bash / Git Bash:   cp configs/local.yaml.example configs/local.yaml
#        PowerShell:        Copy-Item configs/local.yaml.example configs/local.yaml
#   2. Edit the values below if you want the dashboard's optional HPC tab to
#      poll a remote cluster over SSH. Skip the file entirely if you are
#      reproducing the project on a single machine — the dashboard runs
#      end-to-end against the local CSVs/JSONs without any config.
#   3. DO NOT commit `configs/local.yaml` — it is in .gitignore on purpose
#      so each developer keeps their own copy.
#
# WHAT THIS FILE DOES
#   The cortex-dashboard backend reads these values when polling a remote
#   HPC cluster's SLURM queue (see the HpcJobs tab). All other dashboard
#   data comes straight from the local filesystem under
#   `experiments/results/general/` and `data/processed/task1/` — no
#   credentials required.
#
#   Fields marked REQUIRED only matter if you want the HPC tab to talk to
#   a real cluster; leave them as the defaults below for a local-only run
#   and the tab will simply fall back to its mock data.
# ──────────────────────────────────────────────────────────────────────────────

# OPTIONAL — where to reach a remote HPC over SSH (only used by the
# dashboard's HpcJobs tab and the /api/run endpoint).
ssh:
  host: YourHost                              # e.g. 10.10.15.10
  user: YourUsername                          # your HPC login name
  remote_root: /cluster/home/YourUsername/bachelor   # repo path on HPC

# OPTIONAL — Windows username for WSL users. The dashboard searches
# /mnt/c/Users/<windows_user>/.ssh/ for an SSH key when running under WSL.
# Only set this if WSL's $HOME.name differs from your Windows user folder,
# otherwise leave it out / set to null.
# windows_user: null
